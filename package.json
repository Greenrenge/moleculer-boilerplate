{
  "name": "backend-boilerplate",
  "version": "1.0.0",
  "description": "Backend Boilerplate",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon --watch src ",
    "start:repl": "REPL=true npm run start",
    "start:prod": "cross-env NODE_ENV=production node src/index.js",
    "lint": "eslint --ignore-path .eslintignore .",
    "prebuild": "npm run clean",
    "build": "babel src -s -d build",
    "test": "cross-env NODE_ENV=test mocha --recursive \"test/**/*.test.js\" --timeout 60000",
    "test:watch": "cross-env NODE_ENV=test nodemon --watch test --watch src --exec npm run test",
    "clean": "rimraf ./build",
    "migrate": "./node_modules/migrate-mongo/bin/migrate-mongo.js",
    "migrate:create": "./node_modules/migrate-mongo/bin/migrate-mongo.js create",
    "migrate:up": "./node_modules/migrate-mongo/bin/migrate-mongo.js up",
    "migrate:down": "./node_modules/migrate-mongo/bin/migrate-mongo.js down",
    "migrate:status": "./node_modules/migrate-mongo/bin/migrate-mongo.js status",
    "seed:simple": "cross-env LIGHTSHIP_RANDOM_PORT=true babel-node seeds/simple-seed.js",
    "seed:simple:prod": "cross-env NODE_ENV=production LIGHTSHIP_RANDOM_PORT=true babel-node seeds/simple-seed.js"
  },
  "keywords": [],
  "author": "GreenRenge",
  "license": "ISC",
  "dependencies": {
    "@greenrenge/gracefully": "^1.1.0",
    "callsites": "^4.1.0",
    "ioredis": "^4.27.10",
    "jaeger-client": "^3.18.1",
    "lodash": "^4.17.21",
    "migrate-mongo": "^8.2.3",
    "moleculer": "^0.14.32",
    "moleculer-repl": "^0.7.4",
    "mongoose": "^8.0.2",
    "nats": "^1.4.12",
    "redlock": "^4.2.0"
  },
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-mocha": "^10.2.0",
    "eslint-plugin-prettier": "^5.0.1",
    "factory-girl": "^5.0.4",
    "mocha": "^10.2.0",
    "mongodb-memory-server": "^9.1.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "sinon": "^17.0.1",
    "sinon-chai": "^3.7.0"
  }
}
